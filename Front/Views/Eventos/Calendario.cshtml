@{
    ViewData["Title"] = "Calendario";
}

<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <div id="calendar"></div>
</div>

<div id="evento-modal" tabindex="-1" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-lg mx-4 p-6">
        <button type="button" onclick="cerrarModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"/>
            </svg>
        </button>
        <h3 class="text-xl font-bold text-gray-900 mb-4" id="modal-titulo"></h3>
        <div class="space-y-3" id="modal-contenido"></div>
    </div>
</div>


<div id="crear-modal" tabindex="-1" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-lg mx-4 p-6">
        <button type="button" onclick="cerrarCrearModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12"/>
            </svg>
        </button>
        <h3 class="text-xl font-bold text-gray-900 mb-4">Nuevo Evento</h3>

        <div id="crear-error" class="hidden bg-red-50 text-red-700 border border-red-200 rounded-md p-3 mb-4 text-sm"></div>

        <form id="crear-evento-form" class="space-y-4">
            <div>
                <label for="campo-cliente" class="block text-sm font-medium text-gray-700">Cliente</label>
                <select id="campo-cliente" name="clienteId" required
                        class="mt-1 w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="">-- Selecciona un cliente --</option>
                </select>
            </div>

            <div>
                <label for="campo-fecha" class="block text-sm font-medium text-gray-700">Fecha y hora</label>
                <input id="campo-fecha" name="fecha" type="datetime-local" required
                       class="mt-1 w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
            </div>

            <div>
                <label for="campo-descripcion" class="block text-sm font-medium text-gray-700">Descripción</label>
                <input id="campo-descripcion" name="descripcion" maxlength="200"
                       class="mt-1 w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                       placeholder="Ej: Corte de cabello, Manicure..." />
            </div>

            <div>
                <label for="campo-monto" class="block text-sm font-medium text-gray-700">Monto</label>
                <input id="campo-monto" name="monto" type="number" step="0.01"
                       class="mt-1 w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
                       placeholder="0.00 (opcional)" />
            </div>

            <div class="flex gap-2 pt-2">
                <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm hover:bg-blue-700 font-medium">
                    Guardar evento
                </button>
                <button type="button" onclick="cerrarCrearModal()" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200">
                    Cancelar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        window.clientes = @Html.Raw(ViewBag.ClientesJson ?? "[]");
    </script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/locales/es.global.min.js"></script>
    <script src="~/js/calendario.js" asp-append-version="true"></script>
}
