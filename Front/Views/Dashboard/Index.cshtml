@using Front.Models.Dashboard
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">
        Dashboard
    </h1>
    <p class="text-gray-500 mt-2">
        Resumen general de la actividad de tu empresa.
    </p>
</div>

<!-- Tarjetas -->
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">

    <div class="bg-white rounded-xl shadow p-6">
        <p class="text-sm text-gray-500">Clientes Activos</p>
        <h2 class="text-3xl font-bold text-blue-600 mt-2">
            @Model.TotalClientes
        </h2>
    </div>

    <div class="bg-white rounded-xl shadow p-6">
        <p class="text-sm text-gray-500">Eventos</p>
        <h2 class="text-3xl font-bold text-indigo-600 mt-2">
            @Model.TotalEventos
        </h2>
    </div>

    <div class="bg-white rounded-xl shadow p-6">
        <p class="text-sm text-gray-500">Ingresos</p>
        <h2 class="text-3xl font-bold text-green-600 mt-2">
            @Model.IngresosTotales.ToString("C")
        </h2>
    </div>

    <div class="bg-white rounded-xl shadow p-6">
        <p class="text-sm text-gray-500">Eventos Completados</p>
        <h2 class="text-3xl font-bold text-emerald-600 mt-2">
            @Model.EventosCompletados
        </h2>
    </div>

</div>

<!-- Segunda fila -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

    <div class="bg-yellow-50 border border-yellow-100 rounded-xl p-6">
        <p class="text-sm text-yellow-700">Eventos Pendientes</p>
        <h2 class="text-3xl font-bold text-yellow-800 mt-2">
            @Model.EventosPendientes
        </h2>
    </div>

    <div class="bg-green-50 border border-green-100 rounded-xl p-6">
        <p class="text-sm text-green-700">Recordatorios Enviados</p>
        <h2 class="text-3xl font-bold text-green-800 mt-2">
            @Model.RecordatoriosEnviados
        </h2>
    </div>

    <div class="bg-red-50 border border-red-100 rounded-xl p-6">
        <p class="text-sm text-red-700">Recordatorios Fallidos</p>
        <h2 class="text-3xl font-bold text-red-800 mt-2">
            @Model.RecordatoriosFallidos
        </h2>
    </div>

</div>

<!-- Recordatorios pendientes -->
<div class="bg-white rounded-xl shadow p-6 mb-8">

    <div class="flex justify-between items-center">

        <div>
            <h2 class="text-lg font-semibold text-gray-900">
                Recordatorios Pendientes
            </h2>

            <p class="text-gray-500 text-sm mt-1">
                Aún no enviados.
            </p>
        </div>

        <span class="bg-yellow-100 text-yellow-700 px-4 py-2 rounded-full font-semibold">
            @Model.RecordatoriosPendientes
        </span>

    </div>

</div>

<!-- Últimos eventos -->
<div class="bg-white rounded-xl shadow overflow-hidden">

    <div class="p-6 border-b">
        <h2 class="text-lg font-semibold text-gray-900">
            Últimos Eventos
        </h2>
    </div>

    <table class="min-w-full text-sm">

        <thead class="bg-gray-50 text-gray-500">

            <tr>

                <th class="text-left p-4">Cliente</th>

                <th class="text-left p-4">Tipo</th>

                <th class="text-left p-4">Fecha</th>

                <th class="text-left p-4">Monto</th>

                <th class="text-left p-4">Estado</th>

            </tr>

        </thead>

        <tbody>

        @if (Model.UltimosEventos.Any())
        {
            foreach (var evento in Model.UltimosEventos)
            {
                <tr class="border-t hover:bg-gray-50">

                    <td class="p-4 font-medium text-gray-900">
                        @evento.ClienteNombre
                    </td>

                    <td class="p-4">
                        @evento.Tipo
                    </td>

                    <td class="p-4 text-gray-600">
                        @evento.Fecha.ToString("dd/MM/yyyy HH:mm")
                    </td>

                    <td class="p-4 font-semibold text-green-600">
                        @evento.Monto.ToString("C")
                    </td>

                    <td class="p-4">

                        <span class="px-3 py-1 rounded-full text-xs
                            @(evento.Estado == "Completado"
                                ? "bg-green-100 text-green-700"
                                : evento.Estado == "Pendiente"
                                    ? "bg-yellow-100 text-yellow-700"
                                    : "bg-gray-100 text-gray-700")">

                            @evento.Estado

                        </span>

                    </td>

                </tr>
            }
        }
        else
        {
            <tr>

                <td colspan="5" class="text-center py-10 text-gray-500">

                    No existen eventos registrados.

                </td>

            </tr>
        }

        </tbody>

    </table>

</div>