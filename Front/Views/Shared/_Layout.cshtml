@using Front.Extensiones
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RecorApp</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" />
</head>

<body class="bg-gray-50">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- ============ NAVBAR ============ -->
        <nav class="fixed top-0 z-50 w-full bg-white border-b border-gray-200">
            <div class="px-3 py-3 lg:px-5 lg:pl-3">
                <div class="flex items-center justify-between">
                    <div class="flex items-center justify-start">
                        <button data-drawer-target="sidebar" data-drawer-toggle="sidebar" aria-controls="sidebar"
                                type="button"
                                class="sm:hidden text-gray-600 rounded-lg p-2 hover:bg-gray-100 focus:outline-none">
                            <span class="sr-only">Abrir menú</span>
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-width="2"
                                      d="M5 7h14M5 12h14M5 17h10" />
                            </svg>
                        </button>
                        <a asp-page="/Dashboard/Index" class="flex ms-2 md:me-24">
                            <span class="self-center text-lg font-bold whitespace-nowrap text-blue-600">RecorApp</span>
                        </a>
                    </div>

                    <div class="flex items-center">
                        <div class="flex items-center ms-3">
                            <button type="button"
                                    class="flex items-center text-sm bg-gray-100 rounded-full px-3 py-2 hover:bg-gray-200"
                                    aria-expanded="false" data-dropdown-toggle="dropdown-user">
                                <span class="text-gray-700 font-medium">@User.GetNombreNegocio()</span>
                                <svg class="w-4 h-4 ms-2 text-gray-500" fill="none" viewBox="0 0 24 24">
                                    <path stroke="currentColor" stroke-width="2" d="m6 9 6 6 6-6" />
                                </svg>
                            </button>

                            <div class="z-50 hidden bg-white border border-gray-200 rounded-lg shadow-lg w-52"
                                 id="dropdown-user">
                                <div class="px-4 py-3 border-b border-gray-100">
                                    <p class="text-sm font-medium text-gray-900">@User.GetNombreNegocio()</p>
                                    <p class="text-sm text-gray-500 truncate">@User.GetEmail()</p>
                                </div>
                                <ul class="p-2 text-sm text-gray-700 font-medium">
                                    @if (User.IsAdmin())
                                    {
                                        <li>
                                            <a asp-controller="Usuarios" asp-action="Index"
                                               class="flex items-center w-full p-2 hover:bg-gray-100 rounded">
                                                Usuarios
                                            </a>
                                        </li>
                                    }
                                    <li>
                                        <form method="post" asp-controller="Auth" asp-action="Logout">
                                            <button type="submit"
                                                    class="flex items-center w-full p-2 hover:bg-gray-100 rounded text-left text-red-600">
                                                Cerrar sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- ============ SIDEBAR (flotante) ============ -->
        <aside id="sidebar" class="fixed top-20 bottom-4 left-4 z-40 w-64 -translate-x-[150%] sm:translate-x-0 transition-transform
            bg-white border border-gray-200 rounded-2xl shadow-sm flex flex-col overflow-hidden">

            <!-- Navegación -->
            <div class="flex-1 overflow-y-auto px-3 py-4">
                <ul class="space-y-1 font-medium">
                    <li>
                        <a asp-controller="Dashboard" asp-action="Index"
                           class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M10 6.025A7.5 7.5 0 1 0 17.975 14H10V6.025Z" />
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M13.5 3c-.169 0-.334.014-.5.025V11h7.975c.011-.166.025-.331.025-.5A7.5 7.5 0 0 0 13.5 3Z" />
                            </svg>
                            <span class="ms-3">Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Clientes" asp-action="Index"
                           class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-width="2"
                                      d="M16 19h4a1 1 0 0 0 1-1v-1a3 3 0 0 0-3-3h-2m-2.236-4a3 3 0 1 0 0-4M3 18v-1a3 3 0 0 1 3-3h4a3 3 0 0 1 3 3v1a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1Zm8-10a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            </svg>
                            <span class="ms-3">Clientes</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Eventos" asp-action="Index"
                           class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z" />
                            </svg>
                            <span class="ms-3">Eventos</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Eventos" asp-action="Calendario"
                           class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z" />
                            </svg>
                            <span class="ms-3">Calendario</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Pagos" asp-action="Index"
                        class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V6m0 10v2m9-6a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                            </svg>
                            <span class="ms-3">Pagos</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Recordatorios" asp-action="Index"
                           class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z" />
                            </svg>
                            <span class="ms-3">Recordatorios</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Plantillas" asp-action="Index"
                           class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                            <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z" />
                            </svg>
                            <span class="ms-3">Plantillas</span>
                        </a>
                    </li>
                    @if (User.IsAdmin())
                    {
                        <li>
                            <a asp-controller="Usuarios" asp-action="Index"
                               class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                                <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                                    <path stroke="currentColor" stroke-width="2"
                                          d="M16 19h4a1 1 0 0 0 1-1v-1a3 3 0 0 0-3-3h-2m-2.236-4a3 3 0 1 0 0-4M3 18v-1a3 3 0 0 1 3-3h4a3 3 0 0 1 3 3v1a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1Zm8-10a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                </svg>
                                <span class="ms-3">Usuarios</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>

            <!-- Actualizar plan + configuración -->
            @if (User.IsAdmin())
            {
            <div class="px-3 pb-3 pt-2 border-t border-gray-100">
                
                    <a asp-controller="Suscripcion" asp-action="Index"
                       class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group mb-1">
                        <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V6m0 10v2m9-6a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                        </svg>
                        <span class="ms-3">Suscripción</span>
                    </a>

                    <a asp-controller="Configuracion" asp-action="Index"
                   class="flex items-center px-3 py-2 text-gray-700 rounded-lg hover:bg-gray-100 hover:text-blue-600 group">
                    <svg class="w-5 h-5 text-gray-500 group-hover:text-blue-600" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065Z" />
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                    <span class="ms-3">Configuración</span>
                </a>

            </div>
            }

        </aside>


        <div class="p-4 sm:ml-72 pt-24">
            @RenderBody()
        </div>
    }
    else
    {
        @RenderBody()
    }

    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>

</body>

</html>