@{
    ViewData["Title"] = "Pago cancelado";
}

<div class="max-w-lg mx-auto mt-16 text-center">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-10">
        <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </div>

        <h1 class="text-2xl font-bold text-gray-900 mb-2">
            Pago cancelado
        </h1>

        <p class="text-gray-500 mb-8">
            No se realizó ningún cobro. Si cambias de opinión, puedes intentarlo de nuevo.
        </p>

        <a asp-action="Index"
           class="inline-block bg-blue-600 hover:bg-blue-700 text-white rounded-lg px-6 py-3 font-semibold transition">
            Intentar de nuevo
        </a>
    </div>
</div>
