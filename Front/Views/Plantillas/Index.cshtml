@using Front.Models.Plantillas
@model List<PlantillaListItemViewModel>
@{
    ViewData["Title"] = "Plantillas de mensaje";
}

<div class="flex justify-between items-center mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Plantillas de mensaje</h1>
        <p class="text-sm text-gray-500 mt-1">@Model.Count plantilla(s) configurada(s)</p>
    </div>
    <a asp-action="Create"
       class="inline-flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Nueva plantilla
    </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    @if (!Model.Any())
    {
        <div class="col-span-2 bg-white rounded-lg shadow p-6 text-center text-gray-400">
            No hay plantillas configuradas todavía.
        </div>
    }
    @foreach (var plantilla in Model)
    {
        <div class="bg-white rounded-lg shadow p-5">
            <div class="flex justify-between items-start mb-3">
                <span class="px-2 py-1 rounded-full text-xs bg-blue-50 text-blue-700 font-medium">
                    @(plantilla.Tipo == "RecordatorioCita" ? "Recordatorio de Cita" : "Recordatorio de Pago")
                </span>
                <span class="px-2 py-1 rounded-full text-xs @(plantilla.Activo ? "bg-green-50 text-green-700" : "bg-gray-100 text-gray-500")">
                    @(plantilla.Activo ? "Activa" : "Inactiva")
                </span>
            </div>

            <p class="text-sm text-gray-700 whitespace-pre-line mb-4">@plantilla.Contenido</p>

            <div class="flex justify-end gap-1">
                <a asp-action="Edit" asp-route-id="@plantilla.Id"
                   class="text-blue-600 hover:text-blue-800 p-1.5 rounded-lg hover:bg-blue-50 transition" title="Editar">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                </a>
                <form asp-action="Delete" asp-route-id="@plantilla.Id" method="post" class="inline"
                      onsubmit="return confirm('¿Eliminar esta plantilla?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-red-600 hover:text-red-800 p-1.5 rounded-lg hover:bg-red-50 transition" title="Eliminar">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    }
</div>