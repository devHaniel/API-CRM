@model List<Front.Models.Pagos.PagoListItemViewModel>
@{
    ViewData["Title"] = "Pagos pendientes";
    var totalPendiente = Model.Sum(p => p.Monto ?? 0);
    var vencidos = Model.Count(p => p.EstaVencido);
}

<div class="flex justify-between items-center mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Pagos pendientes</h1>
        <p class="text-sm text-gray-500 mt-1">
            @Model.Count pago(s) por cobrar
            @if (vencidos > 0)
            {
                <span class="text-red-600 font-medium">· @vencidos vencido(s)</span>
            }
        </p>
    </div>
    <div class="text-right">
        <p class="text-sm text-gray-500">Total pendiente</p>
        <p class="text-2xl font-bold text-gray-900">@totalPendiente.ToString("C")</p>
    </div>
</div>

@if (TempData["Error"] is not null)
{
    <div class="bg-red-50 text-red-700 border border-red-200 rounded-md p-3 mb-4 text-sm">
        @TempData["Error"]
    </div>
}

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full text-sm">
        <thead>
            <tr class="text-left text-gray-500 border-b bg-gray-50">
                <th class="p-3">Cliente</th>
                <th class="p-3">Descripción</th>
                <th class="p-3">Vence</th>
                <th class="p-3">Monto</th>
                <th class="p-3">Estado</th>
                <th class="p-3 text-right">Acción</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="p-6 text-center text-gray-400">
                        No tienes pagos pendientes. 🎉
                    </td>
                </tr>
            }
            @foreach (var pago in Model)
            {
                <tr class="border-b last:border-0 hover:bg-gray-50">
                    <td class="p-3 font-medium text-gray-900">@pago.ClienteNombre</td>
                    <td class="p-3 text-gray-600">@(pago.Descripcion ?? "-")</td>
                    <td class="p-3 text-gray-600">@pago.Fecha.ToString("dd/MM/yyyy")</td>
                    <td class="p-3 font-medium text-gray-900">@(pago.Monto?.ToString("C") ?? "-")</td>
                    <td class="p-3">
                        <span class="px-2 py-1 rounded-full text-xs @(pago.EstaVencido ? "bg-red-50 text-red-700" : "bg-amber-50 text-amber-700")">
                            @(pago.EstaVencido ? "Vencido" : "Pendiente")
                        </span>
                    </td>
                    <td class="p-3 text-right">
                        <form asp-action="MarcarComoPagado" asp-route-id="@pago.Id" method="post" class="inline"
                              onsubmit="return confirm('¿Confirmas que este pago ya fue cobrado?');">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="bg-green-600 text-white px-3 py-1.5 rounded-md text-xs font-medium hover:bg-green-700 transition">
                                Marcar como pagado
                            </button>
                        </form>
                        <form asp-action="MarcarComoCancelado" asp-route-id="@pago.Id" method="post" class="inline"
                            onsubmit="return confirm('¿Cancelar este pago?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-gray-500 hover:text-red-600 text-xs ml-2">
                                Cancelar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>