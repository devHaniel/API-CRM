@using Application.DTOs.Common
@using Application.DTOs.Recordatorio
@model PagedResultDto<RecordatorioDto>
@{
    ViewData["Title"] = "Recordatorios";
}

<div class="flex justify-between items-center mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Recordatorios</h1>
        <p class="text-sm text-gray-500 mt-1">@Model.TotalCount recordatorio(s) en total</p>
    </div>
    <a asp-action="Create" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition">
        + Nuevo recordatorio
    </a>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="min-w-full text-sm">
        <thead>
            <tr class="text-left text-gray-500 border-b bg-gray-50">
                <th class="p-3">Cliente</th>
                <th class="p-3">Canal</th>
                <th class="p-3">Programado</th>
                <th class="p-3">Enviado</th>
                <th class="p-3">Estado</th>
                <th class="p-3 text-right">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Items)
            {
                <tr class="border-b last:border-0 hover:bg-gray-50">
                    <td class="p-3 font-medium text-gray-900">@r.ClienteNombre</td>
                    <td class="p-3">@r.CanalEnvio</td>
                    <td class="p-3 text-gray-600">@r.FechaProgramada.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="p-3 text-gray-600">@(r.FechaEnvio?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    <td class="p-3">
                        <span class="px-2 py-1 rounded-full text-xs @(r.Estado == "Enviado" ? "bg-green-50 text-green-700" : r.Estado == "Fallido" ? "bg-red-50 text-red-700" : "bg-gray-100 text-gray-700")">
                            @r.Estado
                        </span>
                    </td>
                    <td class="p-3 text-right">
                    <a asp-action="Edit" asp-route-id="@r.Id" class="text-blue-600 hover:underline">Editar</a>

                        <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="inline"
                              onsubmit="return confirm('¿Eliminar este recordatorio?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="text-red-600 hover:underline">Eliminar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>