@using Front.Models.Recordatorios
@model RecordatorioDetailsViewModel

@{
    ViewData["Title"] = "Detalles del Recordatorio";
}

<h1 class="text-2xl font-semibold text-gray-800 mb-6">Detalles del Recordatorio</h1>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

    <div class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
        <h2 class="text-lg font-medium text-gray-800 mb-2">Información del Recordatorio</h2>

        <div>
            <label class="block text-sm font-medium text-gray-700">Cliente</label>
            <p class="mt-1 text-sm text-gray-900">
                @if (Model.ClienteId != Guid.Empty)
                {
                    <a asp-controller="Clientes" asp-action="Details" asp-route-id="@Model.ClienteId"
                       class="text-blue-600 hover:underline">
                        @Model.ClienteNombre
                    </a>
                }
                else
                {
                    <span>@Model.ClienteNombre</span>
                }
            </p>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Evento asociado</label>
            <p class="mt-1 text-sm text-gray-900">
                <a asp-controller="Eventos" asp-action="Details" asp-route-id="@Model.EventoId"
                   class="text-blue-600 hover:underline">
                    @Model.EventoTipo
                </a>
            </p>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Canal de envío</label>
            <span class="mt-1 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
                <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                @Model.CanalEnvio
            </span>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Fecha programada</label>
            <p class="mt-1 text-sm text-gray-900">@Model.FechaProgramada.ToString("dd/MM/yyyy HH:mm")</p>
        </div>

        @if (Model.FechaEnvio.HasValue)
        {
            <div>
                <label class="block text-sm font-medium text-gray-700">Fecha de envío</label>
                <p class="mt-1 text-sm text-gray-900">@Model.FechaEnvio.Value.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        }

        <div>
            <label class="block text-sm font-medium text-gray-700">Estado</label>
            @{
                var badgeClass = Model.Estado switch
                {
                    "Enviado" => "bg-green-100 text-green-700",
                    "Fallido" => "bg-red-100 text-red-700",
                    "Pendiente" => "bg-yellow-100 text-yellow-700",
                    _ => "bg-gray-100 text-gray-700"
                };
                var dotClass = Model.Estado switch
                {
                    "Enviado" => "bg-green-500",
                    "Fallido" => "bg-red-500",
                    "Pendiente" => "bg-yellow-500",
                    _ => "bg-gray-400"
                };
            }
            <span class="mt-1 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium @badgeClass">
                <span class="w-1.5 h-1.5 rounded-full @dotClass"></span>
                @Model.Estado
            </span>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Fecha de creación</label>
            <p class="mt-1 text-sm text-gray-500">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>

    @if (Model.Estado == "Fallido" && !string.IsNullOrWhiteSpace(Model.DetalleError))
    {
        <div class="bg-red-50 border border-red-200 rounded-lg p-6">
            <h2 class="text-lg font-medium text-red-800 mb-2">Detalle del error</h2>
            <p class="text-sm text-red-700 whitespace-pre-wrap">@Model.DetalleError</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h2 class="text-lg font-medium text-gray-800 mb-2">Sin errores</h2>
            <p class="text-sm text-gray-500">Este recordatorio no presenta errores.</p>
        </div>
    }

</div>

<div class="mt-6 flex gap-3">
    <a asp-action="Edit" asp-route-id="@Model.Id"
       class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-gray-300 text-gray-600 hover:bg-gray-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Editar
    </a>
    <a asp-action="Index"
       class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-gray-300 text-gray-600 hover:bg-gray-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Volver
    </a>
</div>
