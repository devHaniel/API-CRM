@using Application.DTOs.Plan
@model IEnumerable<PlanDto>

@{
    ViewData["Title"] = "Planes";
}

<div class="max-w-7xl mx-auto px-4 py-8">

    <!-- Encabezado -->
    <div class="mb-10 text-center">
        <h1 class="text-3xl font-bold text-gray-900">
            Planes disponibles
        </h1>

        <p class="mt-2 text-gray-500 max-w-2xl mx-auto">
            Elige el plan que mejor se adapte al crecimiento de tu empresa.
            Puedes cambiar de plan en cualquier momento.
        </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8 items-stretch">

        @foreach (var plan in Model)
        {
            var popular = plan.Nombre == "Profesional"; // o cualquier lógica

            <div class="relative bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col
                        @(popular ? "lg:-translate-y-4 border-blue-500" : "")">

                @if (popular)
                {
                    <div class="absolute top-5 right-5">
                        <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold">
                            Más popular
                        </span>
                    </div>
                }

                <div class="p-8">

                    <h2 class="text-2xl font-bold text-gray-900">
                        @plan.Nombre
                    </h2>

                    <p class="mt-3 text-gray-500 leading-relaxed">
                        Ideal para empresas que necesitan administrar clientes,
                        eventos y recordatorios.
                    </p>

                    <div class="mt-8 flex items-end gap-2">

                        <span class="text-5xl font-bold text-gray-900">
                            @plan.PrecioMensual.ToString("C0")
                        </span>

                        <span class="text-gray-500 mb-2">
                            /mes
                        </span>

                    </div>

                    <hr class="my-8"/>

                    <ul class="space-y-4">

                        <li class="flex items-center gap-3">

                            <svg class="w-5 h-5 text-green-500"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">

                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M5 13l4 4L19 7"/>

                            </svg>

                            <span class="text-gray-700">
                                @plan.LimiteRecordatoriosMes
                                recordatorios mensuales
                            </span>

                        </li>

                        <li class="flex items-center gap-3">

                            <svg class="w-5 h-5 text-green-500"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">

                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M5 13l4 4L19 7"/>

                            </svg>

                            <span class="text-gray-700">
                                Hasta @plan.MaxUsuarios usuarios
                            </span>

                        </li>

                        <li class="flex items-center gap-3">

                            <svg class="w-5 h-5 text-green-500"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">

                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M5 13l4 4L19 7"/>

                            </svg>

                            <span class="text-gray-700">
                                @plan.PrecioRecordatorioExtra.ToString("C")
                                por recordatorio adicional
                            </span>

                        </li>

                        <li class="flex items-center gap-3">

                            <svg class="w-5 h-5 text-green-500"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24">

                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="2"
                                      d="M5 13l4 4L19 7"/>

                            </svg>

                            <span class="text-gray-700">
                                Soporte incluido
                            </span>

                        </li>

                    </ul>

                </div>

                <div class="mt-auto p-8 pt-0">

                    @if (popular)
                    {
                        <button
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white rounded-lg py-3 font-semibold transition">

                            Cambiar a este plan

                        </button>
                    }
                    else
                    {
                        <button
                            class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg py-3 font-semibold transition">

                            Seleccionar plan

                        </button>
                    }

                </div>

            </div>
        }

    </div>

</div>