@model IEnumerable<Front.Models.Usuarios.UsuarioListItemViewModel>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Usuarios</h2>
    <a asp-action="Create" class="btn btn-primary">Nuevo usuario</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Email</th>
            <th>Rol</th>
            <th>Estado</th>
            <th>Fecha creación</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var usuario in Model)
        {
            <tr>
                <td>@usuario.Email</td>
                <td>@usuario.Rol</td>
                <td>@(usuario.Activo ? "Activo" : "Inactivo")</td>
                <td>@usuario.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@usuario.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    <form asp-action="Delete" asp-route-id="@usuario.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Eliminar este usuario?');">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
